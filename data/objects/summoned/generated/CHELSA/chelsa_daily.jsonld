  "name": "CHELSA-daily (V2.1)",
  "description": "CHELSA-daily is a global, kilometer-scale climate dataset generated with the CHELSA downscaling model. It consists of daily surface variables summarized as daily means, minima, maxima, or (in some cases) daily accumulations.",
  "url": "https://www.chelsa-climate.org/datasets/chelsa_daily",
  "version": "2.1",
