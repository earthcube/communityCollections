      "name": "First Growing Degree Day above 10 °C",
      "alternateName": "gdgfgd10",
      "unitText": "julian day",
      "description": "Julian day of the first occurrence of a daily mean temperature above 10 °C."
    },
    {
      "@type": "PropertyValue",
      "name": "First Growing Degree Day above 5 °C",
      "alternateName": "gdgfgd5",
      "unitText": "julian day",
      "description": "Julian day of the first occurrence of a daily mean temperature above 5 °C."
    },
    {
      "@type": "PropertyValue",
      "name": "Growing Season Length",
      "alternateName": "gsl",
      "unitText": "days",
      "description": "Number of days between the first and last occurrence of growing season conditions."
    },
    {
