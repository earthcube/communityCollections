    "url": "https://www.wsl.ch/"
  },
  "publisher": {
    "@type": "Organization",
    "@id": "https://www.chelsa-climate.org/#publisher",
    "name": "WSL (Swiss Federal Institute for Forest, Snow and Landscape Research)",
    "url": "https://www.wsl.ch/"
  },
  "temporalCoverage": "1981-2010/1971-2100",
  "spatialCoverage": {
    "@type": "Place",
    "name": "Global land surface areas",
    "geo": {
      "@type": "GeoShape",
      "box": "-180.0,-60.0 180.0,90.0"
    }
  },
  "keywords": [
    "CHELSA",
    "bioclim",
