  "@id": "https://www.chelsa-climate.org/datasets/chelsa_bioclim#dataset",
  "name": "CHELSA-bioclim (V2.1)",
  "description": "CHELSA-bioclim is a global, kilometer-scale climate dataset generated with the CHELSA downscaling model. It consists of bioclimatic variables and related predictors used in ecological and environmental analyses.",
  "url": "https://www.chelsa-climate.org/datasets/chelsa_bioclim",
  "version": "2.1",
