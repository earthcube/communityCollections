  "@id": "https://www.chelsa-climate.org/datasets/chelsa_monthly#dataset",
  "name": "CHELSA-monthly (V2.1)",
  "description": "CHELSA-monthly is a global, kilometer-scale climate dataset generated with the CHELSA downscaling model. It consists of monthly aggregated surface variables summarized as monthly means or (in some cases) monthly accumulations.",
  "url": "https://www.chelsa-climate.org/datasets/chelsa_monthly",
  "version": "2.1",
  "creator": {
