      "name": "Total Cloud Cover Percentage",
      "alternateName": "clt",
      "unitText": "percent",
      "description": "Total cloud area fraction, reported as a percentage, for the whole atmospheric column.",
      "temporalCoverage": "1979-01-15/2021-12-15",
      "spatialCoverage": {
        "@type": "Place",
        "name": "Global land surface areas",
